{
  "in-process": {
    "label": "In-Process",
    "packageManagers": [
      "deno",
      "bun",
      "npm",
      "yarn",
      "pnpm"
    ],
    "imports": {
      "@fedify/fedify": {
        "InProcessMessageQueue": "InProcessMessageQueue"
      }
    },
    "object": "new InProcessMessageQueue()"
  },
  "redis": {
    "label": "Redis",
    "packageManagers": [
      "deno",
      "bun",
      "npm",
      "yarn",
      "pnpm"
    ],
    "dependencies": {
      "npm:ioredis": "^5.10.1"
    },
    "imports": {
      "@fedify/redis": {
        "RedisMessageQueue": "RedisMessageQueue"
      },
      "ioredis": {
        "Redis": "Redis"
      }
    },
    "object": "new RedisMessageQueue(() => new Redis(process.env.REDIS_URL))",
    "env": {
      "REDIS_URL": "redis://localhost:6379"
    }
  },
  "postgres": {
    "label": "PostgreSQL",
    "packageManagers": [
      "deno",
      "bun",
      "npm",
      "yarn",
      "pnpm"
    ],
    "dependencies": {
      "npm:postgres": "^3.4.8"
    },
    "imports": {
      "@fedify/postgres": {
        "PostgresMessageQueue": "PostgresMessageQueue"
      },
      "postgres": {
        "default": "postgres"
      }
    },
    "object": "new PostgresMessageQueue(postgres(process.env.POSTGRES_URL))",
    "env": {
      "POSTGRES_URL": "postgres://postgres@localhost:5432/postgres"
    }
  },
  "mysql": {
    "label": "MySQL/MariaDB",
    "packageManagers": [
      "deno",
      "bun",
      "npm",
      "yarn",
      "pnpm"
    ],
    "dependencies": {
      "npm:mysql2": "^3.20.0"
    },
    "imports": {
      "@fedify/mysql": {
        "MysqlMessageQueue": "MysqlMessageQueue"
      },
      "mysql2/promise": {
        "default": "mysql"
      }
    },
    "object": "new MysqlMessageQueue(mysql.createPool(process.env.MYSQL_URL))",
    "env": {
      "MYSQL_URL": "mysql://root@localhost/fedify"
    }
  },
  "amqp": {
    "label": "AMQP (e.g., RabbitMQ)",
    "packageManagers": [
      "deno",
      "bun",
      "npm",
      "yarn",
      "pnpm"
    ],
    "dependencies": {
      "npm:amqplib": "^0.10.9"
    },
    "devDependencies": {
      "npm:@types/amqplib": "^0.10.8"
    },
    "imports": {
      "@fedify/amqp": {
        "AmqpMessageQueue": "AmqpMessageQueue"
      },
      "amqplib": {
        "connect": "connect"
      }
    },
    "object": "new AmqpMessageQueue(await connect(process.env.AMQP_URL))",
    "env": {
      "AMQP_URL": "amqp://localhost"
    }
  },
  "denokv": {
    "label": "Deno KV",
    "packageManagers": [
      "deno"
    ],
    "imports": {
      "@fedify/denokv": {
        "DenoKvMessageQueue": "DenoKvMessageQueue"
      }
    },
    "object": "new DenoKvMessageQueue(await Deno.openKv())",
    "denoUnstable": [
      "kv"
    ]
  }
}
